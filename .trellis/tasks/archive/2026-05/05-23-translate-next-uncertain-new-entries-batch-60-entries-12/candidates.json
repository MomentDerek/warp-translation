  {"id": "01KQXQV12G822RT3ZDK0TWGYJR", "source": "The model used when the agent takes control of your computer to interact with graphical applications through mouse movements, clicks, and keyboard input.", "file": "app/src/ai/execution_profiles/editor/ui_helpers.rs", "line": 283},
